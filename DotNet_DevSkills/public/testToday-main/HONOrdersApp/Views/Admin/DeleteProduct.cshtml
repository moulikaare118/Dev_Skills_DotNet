@model Product
@using DataAccess.Model

@{
    ViewData["Title"] = "Delete Product";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h3 class="text-danger">Delete Product</h3>
            <hr />

            <p class="alert alert-warning">
                Are you sure you want to delete this product? This action cannot be undone.
            </p>

            <div class="card">
                <div class="card-body">
                    <p><strong>Product Name:</strong> @Model.Name</p>
                    <p><strong>SKU:</strong> @Model.Sku</p>
                    <p><strong>Category:</strong> @Model.Category</p>
                    <p><strong>Unit Price:</strong> @Model.UnitPrice.ToString("C")</p>
                    <p><strong>Stock Quantity:</strong> @Model.StockQuantity</p>
                </div>
            </div>

            <form asp-action="DeleteProduct" asp-route-id="@Model.Id" method="post" class="mt-4">
                <button type="submit" class="btn btn-danger">Confirm Delete</button>
                <a asp-action="Products" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
