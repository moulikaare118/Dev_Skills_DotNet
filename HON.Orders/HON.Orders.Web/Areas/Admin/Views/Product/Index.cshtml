@{
    ViewData["Title"] = "Product Management";
}

<div class="row mb-4">
    <div class="col-md-8">
        <h1>Products</h1>
    </div>
    <div class="col-md-4 text-end">
        <a asp-action="Create" class="btn btn-primary">Add New Product</a>
    </div>
</div>

<!-- TODO: Add TempData success/error message display -->

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>SKU</th>
                <th>Price</th>
                <th>Category</th>
                <th>Stock</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <!-- TODO: Loop through products and display rows -->
            <tr>
                <td colspan="7" class="text-center text-muted">No products found. <a asp-action="Create">Create one</a></td>
            </tr>
        </tbody>
    </table>
</div>

