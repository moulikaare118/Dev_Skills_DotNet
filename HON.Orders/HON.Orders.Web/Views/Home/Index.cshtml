@model HomeDashboardViewModel

@{
  ViewData["Title"] = "Dashboard";
}

<!-- TODO: Display dashboard summary cards and recent orders for the HON Orders admin dashboard. -->
<div class="row mb-4">
  <div class="col-md-12">
    <h1>Dashboard</h1>
  </div>
</div>

<div class="row g-4 mb-5">
  <div class="col-md-4">
    <div class="card p-4">
      <h5>Total Orders</h5>
      <p class="display-6">@Model.TotalOrders</p>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card p-4">
      <h5>Pending Orders</h5>
      <p class="display-6">@Model.PendingOrders</p>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card p-4">
      <h5>Total Revenue</h5>
      <p class="display-6">@Model.TotalRevenue.ToString("C")</p>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    Recent Orders
  </div>
  <div class="table-responsive">
    <table class="table table-striped">
      <thead>
        <tr>
          <th>Order #</th>
          <th>Customer</th>
          <th>Date</th>
          <th>Total</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var order in Model.RecentOrders)
        {
          <tr>
            <td>@order.OrderNumber</td>
            <td>@order.Customer.Name</td>
            <td>@order.OrderDate.ToString("yyyy-MM-dd")</td>
            <td>@order.Total.ToString("C")</td>
            <td>@order.Status</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
