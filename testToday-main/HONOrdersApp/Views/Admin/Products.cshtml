@model List<Product>
@using DataAccess.Model

@{
    ViewData["Title"] = "Admin - Products";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>Product Management</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="CreateProduct" class="btn btn-success">+ New Product</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model?.Count > 0)
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Product Name</th>
                    <th>SKU</th>
                    <th>Category</th>
                    <th>Unit Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Name</td>
                        <td>@product.Sku</td>
                        <td>@product.Category</td>
                        <td>@product.UnitPrice.ToString("C")</td>
                        <td>@product.StockQuantity</td>
                        <td>
                            <a asp-action="EditProduct" asp-route-id="@product.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="DeleteProduct" asp-route-id="@product.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="alert alert-info">No products found. <a asp-action="CreateProduct">Create one now</a></p>
    }
</div>
